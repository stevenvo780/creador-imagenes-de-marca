            "data-layout": "lockup_horizontal"
          }
        },
        "lockup_vertical": {
          "description": "Bloque vertical (símbolo arriba del texto)",
          "data_attrs": {
            "data-layout": "lockup_vertical"
          }
        }
      }
    },
