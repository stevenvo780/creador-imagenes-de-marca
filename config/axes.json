{
  "axes": {
    "palette_scheme": {
      "label": "Paleta de color",
      "type": "enum",
      "options": {
        "brand": {
          "description": "Paleta completa de la marca (por defecto)",
          "overrides": {}
        },
        "mono": {
          "description": "Monocromo: texto/fondo invertidos, sin acento",
          "overrides": {
            "acento": "var(--texto)",
            "acento_2": "var(--texto)",
            "bg": "var(--texto)"
          }
        },
        "light": {
          "description": "Modo claro: fondo/texto invertidos",
          "overrides": {
            "bg": "var(--texto)",
            "texto": "var(--primario)"
          }
        },
        "dark": {
          "description": "Modo oscuro: primario como fondo",
          "overrides": {
            "bg": "var(--primario)"
          }
        },
        "accent_bg": {
          "description": "Acento como fondo",
          "overrides": {
            "bg": "var(--acento)",
            "texto": "var(--primario)"
          }
        },
        "gradient": {
          "description": "Fondo degradado (gradiente hero)",
          "overrides": {
            "bg": "var(--grad-hero)"
          }
        }
      }
    },
    "typography_pairing": {
      "label": "Tipografía",
      "type": "enum",
      "options": {
        "brand_default": {
          "description": "Tipografía por defecto de la marca",
          "overrides": {}
        },
        "sans_serif": {
          "description": "Sans-serif moderno (Inter/System)",
          "overrides": {
            "font_titulo": "Inter",
            "font_cuerpo": "Inter"
          }
        },
        "serif_modern": {
          "description": "Título serif con cuerpo sans",
          "overrides": {
            "font_titulo": "Playfair Display",
            "font_cuerpo": "Inter"
          }
        },
        "display": {
          "description": "Tipografías display",
          "overrides": {
            "font_titulo": "Playfair Display",
            "font_cuerpo": "Playfair Display"
          }
        },
        "geometric_sans": {
          "description": "Título grotesco geométrico (Space Grotesk) con cuerpo sans",
          "overrides": {
            "font_titulo": "Space Grotesk",
            "font_cuerpo": "Inter"
          }
        }
      }
    },
    "layout": {
      "label": "Composición",
      "type": "enum",
      "options": {
        "symbol_only": {
          "description": "Solo símbolo (sin texto)",
          "data_attrs": {
            "data-layout": "symbol_only"
          }
        },
        "wordmark_only": {
          "description": "Solo texto (wordmark)",
          "data_attrs": {
            "data-layout": "wordmark_only"
          }
        },
        "lockup_horizontal": {
          "description": "Bloque horizontal (símbolo + texto lado a lado)",
