{
  "axes": {
    "palette_scheme": {
      "label": "Paleta de color",
      "type": "enum",
      "options": {
        "brand": {
          "description": "Paleta completa de la marca (por defecto)",
          "overrides": {}
        },
        "mono": {
          "description": "Monocromo: texto/fondo invertidos, sin acento",
          "overrides": {
            "acento": "var(--texto)",
            "acento_2": "var(--texto)",
            "bg": "var(--texto)"
          }
        },
        "light": {
          "description": "Modo claro: fondo/texto invertidos",
          "overrides": {
            "bg": "var(--texto)",
            "texto": "var(--primario)"
          }
        },
        "dark": {
          "description": "Modo oscuro: primario como fondo",
          "overrides": {
            "bg": "var(--primario)"
          }
        },
        "accent_bg": {
          "description": "Acento como fondo",
          "overrides": {
            "bg": "var(--acento)",
            "texto": "var(--primario)"
          }
        },
        "gradient": {
          "description": "Fondo degradado (gradiente hero)",
          "overrides": {
            "bg": "var(--grad-hero)"
          }
        }
      }
    },
    "typography_pairing": {
      "label": "Tipografía",
      "type": "enum",
      "options": {
        "brand_default": {
          "description": "Tipografía por defecto de la marca",
          "overrides": {}
        },
        "sans_serif": {
          "description": "Sans-serif moderno (Inter/System)",
          "overrides": {
            "font_titulo": "Inter",
            "font_cuerpo": "Inter"
          }
        },
        "serif_modern": {
          "description": "Título serif con cuerpo sans",
          "overrides": {
            "font_titulo": "Playfair Display",
            "font_cuerpo": "Inter"
          }
        },
        "display": {
          "description": "Tipografías display",
          "overrides": {
            "font_titulo": "Playfair Display",
            "font_cuerpo": "Playfair Display"
          }
        },
        "geometric_sans": {
          "description": "Título grotesco geométrico (Space Grotesk) con cuerpo sans",
          "overrides": {
            "font_titulo": "Space Grotesk",
            "font_cuerpo": "Inter"
          }
        }
      }
    },
    "layout": {
      "label": "Composición",
      "type": "enum",
      "options": {
        "symbol_only": {
          "description": "Solo símbolo (sin texto)",
          "data_attrs": {
            "data-layout": "symbol_only"
          }
        },
        "wordmark_only": {
          "description": "Solo texto (wordmark)",
          "data_attrs": {
            "data-layout": "wordmark_only"
          }
        },
        "lockup_horizontal": {
          "description": "Bloque horizontal (símbolo + texto lado a lado)",
          "data_attrs": {
            "data-layout": "lockup_horizontal"
          }
        },
        "lockup_vertical": {
          "description": "Bloque vertical (símbolo arriba del texto)",
          "data_attrs": {
            "data-layout": "lockup_vertical"
          }
        }
      }
    },
    "background_treatment": {
      "label": "Fondo",
      "type": "enum",
      "options": {
        "solid": {
          "description": "Fondo de color sólido",
          "overrides": {
            "bg": "var(--primario)"
          }
        },
        "gradient": {
          "description": "Fondo degradado",
          "overrides": {
            "bg": "var(--grad-bg)"
          }
        },
        "geometric": {
          "description": "Patrón geométrico",
          "data_attrs": {
            "data-bg-treatment": "geometric"
          }
        },
        "grid": {
          "description": "Superposición de cuadrícula",
          "data_attrs": {
            "data-bg-treatment": "grid"
          }
        },
        "orb": {
          "description": "Efecto de orbe radial",
          "data_attrs": {
            "data-bg-treatment": "orb"
          }
        },
        "texture": {
          "description": "Textura sutil",
          "data_attrs": {
            "data-bg-treatment": "texture"
          }
        }
      }
    },
    "density_scale": {
      "label": "Espaciado",
      "type": "enum",
      "options": {
        "compact": {
          "description": "Compacto: escala 85%",
          "overrides": {
            "font_size_scale": "0.85",
            "space_scale": "0.85"
          }
        },
        "normal": {
          "description": "Normal: escala 100% (por defecto)",
          "overrides": {
            "font_size_scale": "1",
            "space_scale": "1"
          }
        },
        "spacious": {
          "description": "Amplio: escala 115%",
          "overrides": {
            "font_size_scale": "1.15",
            "space_scale": "1.15"
          }
        }
      }
    },
    "corner_shape": {
      "label": "Esquinas",
      "type": "enum",
      "options": {
        "sharp": {
          "description": "Esquinas rectas (0px)",
          "overrides": {
            "corner_radius": "0"
          }
        },
        "rounded": {
          "description": "Esquinas redondeadas (14px)",
          "overrides": {
            "corner_radius": "14px"
          }
        },
        "pill": {
          "description": "Forma de píldora (999px)",
          "overrides": {
            "corner_radius": "999px"
          }
        }
      }
    },
    "isotype_style": {
      "label": "Estilo de símbolo",
      "type": "enum",
      "options": {
        "none": {
          "description": "Sin estilo adicional (preservar apariencia actual)",
          "data_attrs": {}
        },
        "lettermark": {
          "description": "Variante de monograma (una letra)",
          "data_attrs": {
            "data-isotype-style": "lettermark"
          }
        },
        "geometric": {
          "description": "Forma geométrica abstracta",
          "data_attrs": {
            "data-isotype-style": "geometric"
          }
        },
        "abstract": {
          "description": "Forma orgánica abstracta",
          "data_attrs": {
            "data-isotype-style": "abstract"
          }
        },
        "enclosure": {
          "description": "Marca encerrada en una forma",
          "data_attrs": {
            "data-isotype-style": "enclosure"
          }
        }
      }
    },
    "accent_placement": {
      "label": "Acento",
      "type": "enum",
      "options": {
        "none": {
          "description": "Sin acento (por defecto)",
          "data_attrs": {}
        },
        "underline": {
          "description": "Barra de acento subrayada",
          "data_attrs": {
            "data-accent-placement": "underline"
          }
        },
        "corner": {
          "description": "Marcador de acento en esquina",
          "data_attrs": {
            "data-accent-placement": "corner"
          }
        },
        "sidebar": {
          "description": "Franja de acento lateral",
          "data_attrs": {
            "data-accent-placement": "sidebar"
          }
        },
        "dot": {
          "description": "Elemento de acento en punto",
          "data_attrs": {
            "data-accent-placement": "dot"
          }
        }
      }
    }
  }
}