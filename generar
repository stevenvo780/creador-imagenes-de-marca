#!/usr/bin/env bash
# generar <marca> [--layout <id>] [--solo-cambios]
# Wrapper conveniente para render.py
# Uso:  ./generar agora
#       ./generar steven-vallejo --layout og_general
#       ./generar all --solo-cambios

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Verificar que se paso al menos la marca
if [[ $# -lt 1 ]]; then
  echo "Uso: ./generar <marca> [--layout <id>] [--solo-cambios]"
  echo ""
  echo "Marcas disponibles:"
  ls marcas/*.json 2>/dev/null | xargs -I{} basename {} .json | sed 's/^/  /'
  echo ""
  echo "Layouts disponibles:"
  python3 render.py --lista-layouts 2>/dev/null || true
  exit 1
fi

MARCA="$1"
shift  # quita el primer argumento; el resto se pasan a render.py

# Detectar un Python que realmente pueda ejecutar render.py.
# Algunos venv locales existen para difusion/GPU y no incluyen Playwright.
PYTHON=""
for candidate in "$SCRIPT_DIR/venv2/bin/python3" "$SCRIPT_DIR/venv/bin/python3" "python3"; do
  if command -v "$candidate" >/dev/null 2>&1 && "$candidate" - <<'PY' >/dev/null 2>&1
import playwright
PY
  then
    PYTHON="$candidate"
    break
  fi
done

if [[ -z "$PYTHON" ]]; then
  echo "[generar] ERROR: no encontre un Python con Playwright instalado."
  echo "Instala dependencias con: python3 -m pip install -r requirements.txt && python3 -m playwright install chromium"
  exit 1
fi

echo "[generar] Marca: $MARCA  Python: $PYTHON"
exec "$PYTHON" render.py --marca "$MARCA" "$@"
